# initialize autocompletion
autoload -U compinit && compinit

export EDITOR="vim -f"

# Set up go
export GOPRIVATE="github.com/moov-io/*,github.com/moovfinancial/*"
export GOPATH=$HOME/go
export GOROOT="$(brew --prefix golang)/libexec"
export PATH=$PATH:${GOPATH}/bin:${GOROOT}/bin

export GOOGLE_CLOUD_PROJECT=moov-gemini

# Secrets - need to be moved to a secrets.env file
[[ -f ~/.secrets.env ]] && source ~/.secrets.env

# load aliases
[[ -f ~/.aliases ]] && source ~/.aliases

setopt prompt_subst
# Function to get the current Git branch and status
parse_git_branch() {
    # Check if we are inside a Git repository
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        # Get the branch name
        local branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)
        # Check for staged changes (index vs HEAD)
        local staged=""
        if ! git diff --cached --quiet 2>/dev/null; then
            staged="+"
        fi

        # Check for unstaged changes (working tree vs index)
        local unstaged=""
        if ! git diff --quiet 2>/dev/null; then
            unstaged="*"
        fi

        # Build the status indicator
        local git_status="${staged}${unstaged}"
        if [[ -n "$git_status" ]]; then
            echo " ($branch$git_status)"
        else
            echo " ($branch)"
        fi
    fi
}

# Set the prompt
# %n = user | %~ = path | $(parse_git_branch) = git info
export PROMPT='%F{cyan}%n%f %F{blue}%~%f$(parse_git_branch) %# '
export PROMPT_EOL_MARK=""


